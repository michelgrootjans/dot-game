<div class="px-4 pt-5 my-5 text-center border-bottom">
  <h1 class="display-4 fw-bold">{{title}}</h1>
  <div class="col-lg-6 mx-auto">
    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mb-5">
      <form method="post" action="/games">

        <input type="hidden" name="title" value="The Food Truck Game">
        <input type="hidden" name="taskNames" value="Order">
        <input type="hidden" name="taskNames" value="Payment">
        <input type="hidden" name="taskNames" value="Preparation">
        <input type="hidden" name="taskNames" value="Packaging">
        <input type="hidden" name="taskNames" value="Customer">

        <button type="submit" class="btn btn-primary btn-lg px-4 me-sm-3">Start</button>
      </form>

    </div>
  </div>
  <div style="max-height: 30vh;">
    <div class="container px-5">
      <img src="img/foodtruck-process.png" class="img-fluid border rounded-3 shadow-lg mb-4" alt="Foodtruck process" width="700" height="500" loading="lazy">
    </div>
  </div>
</div>
