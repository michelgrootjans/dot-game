<div class="container" id="container" data-game-id="{{game.gameId}}">
    <div class="row">
        <div class="col">
            <h1>{{game.title}}</h1>
        </div>
        <div class="col">
            <button id="start-iteration">Start Iteration</button>
<!--            <button id="stop-iteration">Stop Iteration</button>-->

            <label>
                Minutes
                <input id="iteration-length" type="text" value="2">
            </label>
        </div>

    </div>

    <div class="row">
        {{>iteration-stats }}

        <div class="col collapse show toggle-chart">
            <p data-bs-toggle="collapse" data-bs-target=".toggle-chart">
                Show charts
            </p>
        </div>

        <div class="col chart-container collapse toggle-chart" data-bs-toggle="collapse" data-bs-target=".toggle-chart">
            <canvas id="cfd"></canvas>
        </div>
        <div class="col chart-container collapse toggle-chart" data-bs-toggle="collapse" data-bs-target=".toggle-chart">
            <canvas id="scatter"></canvas>
        </div>

    </div>

    <div class="row">
        <progress value="" max="" id="progressbar"></progress>
        <input type="range" id="timeline-slider" hidden>
    </div>

    <div id="board" class="row">
        {{#each game.columnGroups}}
            {{#if this.wait}}
                <div class="board-column-group {{this.main.columnType}}">
                    <h2 style="border-bottom-color: {{this.main.borderColor}}">
                        <a href="/games/{{../game.gameId}}/{{this.main.columnId}}" target="_blank">{{this.main.title}}</a>
                        <span class="participants"></span>
                    </h2>
                    <div class="d-flex">
                        <div class="board-sub-column {{this.main.columnType}}" data-column-id="{{this.main.columnId}}">
                            <h4></h4>
                            <div class="tasks"></div>
                        </div>
                        <div class="board-sub-column wait-column" data-column-id="{{this.wait.columnId}}">
                            <h4></h4>
                            <div class="tasks"></div>
                        </div>
                    </div>
                </div>
            {{else}}
                <div class="col board-column {{this.main.columnType}}" data-column-id="{{this.main.columnId}}">
                    <h2 style="border-bottom-color: {{this.main.borderColor}}">
                        <a href="/games/{{../game.gameId}}/{{this.main.columnId}}" target="_blank">{{this.main.title}}</a>
                        <span class="participants"></span>
                    </h2>
                    <h4></h4>
                    <div class="tasks"></div>
                </div>
            {{/if}}
        {{/each}}
        <div class="col board-column done-column">
            {{#each game.endColumns}}
            <div class="row">
                <div class="col" data-column-id="{{columnId}}">
                    <h2 style="border-bottom-color: {{borderColor}}">{{title}}</h2>
                    <h4></h4>
                    <div class="tasks"></div>
                </div>
            {{/each}}
        </div>
        </div>
    </div>

</div>

{{>cardtemplate-show }}
{{>playertemplate }}

